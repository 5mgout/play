#!name=TG跳转Nagram
#!desc=把 t.me 链接自动跳转到 Nagram 打开
#!author=Minis
#!icon=https://telegram.org/img/t_logo.png

[Script]
TG-Nagram = type=http-response, pattern=^https?://(t\.me|telegram\.(me|dog|org)), requires-body=true, max-size=5242880, script-path=/TG-Nagram.js, timeout=30

[Script]
TG-Nagram.js = type=http-response, script-update-interval=0, script-path=https://raw.githubusercontent.com/minis-ai/scripts/main/tg-nagram.js, timeout=30
